local function getPath(obj)
    local path = obj.Name
    local current = obj.Parent
    while current and current ~= Workspace and current ~= game do
        path = current.Name .. "." .. path
        current = current.Parent
    end
    if current == Workspace then path = "workspace." .. path end
    return path
end

local function scanDescendants(parent, depth, maxDepth)
    if depth > maxDepth then return {Name = "...", ClassName = "MaxDepth", Path = "(truncated)", Type = "TRUNCATED"} end
    local results = {}
    for _, child in ipairs(parent:GetChildren()) do
        local info = {
            Name = child.Name,
            ClassName = child.ClassName,
            Path = getPath(child),
        }
        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") or child:IsA("BindableEvent") or child:IsA("BindableFunction") then
            info.Type = "REMOTE"
        elseif child:IsA("ModuleScript") then
            info.Type = "MODULE"
            pcall(function()
                local source = child.Source
                if source and #source < 10000 then
                    info.Source = source
                elseif source then
                    info.Source = source:sub(1, 10000) .. "... [truncated]"
                end
            end)
        elseif child:IsA("LocalScript") or child:IsA("Script") then
            info.Type = "SCRIPT"
        elseif child:IsA("BasePart") or child:IsA("MeshPart") or child:IsA("Part") then
            info.Type = "PART"
            info.Position = {x = math.floor(child.Position.X), y = math.floor(child.Position.Y), z = math.floor(child.Position.Z)}
        elseif child:IsA("Model") and child:FindFirstChildOfClass("Humanoid") then
            info.Type = "NPC/MOB"
        elseif child:IsA("Model") then
            info.Type = "MODEL"
        elseif child:IsA("Folder") then
            info.Type = "FOLDER"
        end
        if child:GetAttributes() and next(child:GetAttributes()) then
            info.Attributes = child:GetAttributes()
        end
        if #child:GetChildren() > 0 then
            info.Children = scanDescendants(child, depth + 1, maxDepth)
        end
        table.insert(results, info)
    end
    return results
end

local function formatOutput(data, indent)
    indent = indent or 0
    local pad = string.rep("  ", indent)
    local output = ""
    for _, item in ipairs(data) do
        local typeTag = item.Type and ("[" .. item.Type .. "] ") or ""
        output = output .. pad .. typeTag .. item.Path .. " (" .. item.ClassName .. ")\n"
        if item.Position then
            output = output .. pad .. "  Position: " .. item.Position.x .. ", " .. item.Position.y .. ", " .. item.Position.z .. "\n"
        end
        if item.Attributes then
            output = output .. pad .. "  Attributes: "
            for k, v in pairs(item.Attributes) do
                output = output .. k .. "=" .. tostring(v) .. " "
            end
            output = output .. "\n"
        end
        if item.Source then
            output = output .. pad .. "  --- SOURCE ---\n" .. item.Source .. "\n  --- END SOURCE ---\n"
        end
        if item.Children and #item.Children > 0 then
            output = output .. formatOutput(item.Children, indent + 1)
        end
    end
    return output
end

local function scanService(serviceName)
    local service = nil
    pcall(function() service = game:GetService(serviceName) end)
    if not service then return "" end
    local output = "\n--- " .. serviceName:upper() .. " ---\n"
    local data = scanDescendants(service, 0, S.scanDepth)
    output = output .. formatOutput(data)
    return output
end

local function fullScan()
    local gameName = "Unknown"
    pcall(function() gameName = MarketplaceService:GetProductInfo(game.PlaceId).Name end)
    local output = "=== " .. gameName .. " ===\n"
    output = output .. "Place ID: " .. game.PlaceId .. "\n"
    output = output .. "Job ID: " .. game.JobId .. "\n"
    output = output .. "Scanned by: " .. player.Name .. "\n"
    output = output .. "Time: " .. os.date("%Y-%m-%d %H:%M:%S") .. "\n"
    output = output .. "Depth: " .. S.scanDepth .. "\n\n"
    if S.scanWorkspace then output = output .. scanService("Workspace") end
    if S.scanReplicatedStorage then output = output .. scanService("ReplicatedStorage") end
    if S.scanReplicatedFirst then output = output .. scanService("ReplicatedFirst") end
    if S.scanStarterGui then output = output .. scanService("StarterGui") end
    if S.scanServerScriptService then output = output .. scanService("ServerScriptService") end
    if S.scanServerStorage then output = output .. scanService("ServerStorage") end
    return gameName, output
end

local function pushToGithub(gameName, content)
    local safeName = gameName:gsub("[^%w%s]", ""):gsub("%s+", "_")
    local filename = safeName .. "_" .. game.PlaceId .. ".txt"
    local apiUrl = "https://api.github.com/repos/" .. REPO_OWNER .. "/" .. REPO_NAME .. "/contents/" .. filename
    
    -- Lua 5.1 compatible base64 encoding (no bitwise operators)
    local function encodeBase64(str)
        local b64chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
        local result = {}
        local i = 1
        while i <= #str do
            local a, b, c = str:byte(i), str:byte(i+1), str:byte(i+2)
            b = b or 0
            c = c or 0
            local n = a * 65536 + b * 256 + c
            local c1 = math.floor(n / 262144) % 64
            local c2 = math.floor(n / 4096) % 64
            local c3 = math.floor(n / 64) % 64
            local c4 = n % 64
            table.insert(result, b64chars:sub(c1+1, c1+1))
            table.insert(result, b64chars:sub(c2+1, c2+1))
            if i+1 <= #str then
                table.insert(result, b64chars:sub(c3+1, c3+1))
            else
                table.insert(result, "=")
            end
            if i+2 <= #str then
                table.insert(result, b64chars:sub(c4+1, c4+1))
            else
                table.insert(result, "=")
            end
            i = i + 3
        end
        return table.concat(result)
    end
    
    local encodedContent = encodeBase64(content)
    
    local body = HttpService:JSONEncode({
        message = "Auto-scan: " .. gameName .. " (" .. game.PlaceId .. ")",
        content = encodedContent
    })
    
    local success, response = pcall(function()
        return HttpService:RequestAsync({
            Url = apiUrl,
            Method = "PUT",
            Headers = {
                ["Authorization"] = "Bearer " .. GITHUB_TOKEN,
                ["Content-Type"] = "application/json",
                ["Accept"] = "application/vnd.github.v3+json",
                ["User-Agent"] = "CyphraScanner"
            },
            Body = body
        })
    end)
    
    return success, response
end

